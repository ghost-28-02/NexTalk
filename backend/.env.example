# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=mongodb://localhost:27017/NexTalk

# JWT — generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (optional — app runs without it, file uploads will fail)
CLOUDINARY_CLOUD_NAME=dfryej1yt
CLOUDINARY_API_KEY=574166877922519
CLOUDINARY_API_SECRET=vxOd-6WPI18X6Mfbux6qv8JQ9TQ
FOLDER_NAME=NexTalk

# ─── Email (Brevo transactional SMTP) ────────────────────────────────────────
# Get SMTP credentials from: Brevo dashboard → SMTP & API → SMTP tab → Generate new SMTP key
# Leave empty in development — emails will print to the terminal (console adapter)
EMAIL_PROVIDER=console                              # 'brevo' in production, 'console' in dev
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_smtp_login_here        # Usually your Brevo account email
BREVO_SMTP_PASSWORD=your_brevo_smtp_key_here       # The generated SMTP key (not your password)
EMAIL_FROM_NAME=NexTalk
EMAIL_FROM_ADDRESS=noreply@yourdomain.com          # Must be a verified sender in Brevo

